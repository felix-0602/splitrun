{
  "version": "1.0",
  "description": "DEEPSHIP Work Unit 生命周期一致性测试。StateStore + Policy Engine 必须全部通过。",
  "cases": [
    {"name":"WU pending→in_progress 合法","action":"update_work_unit","wu_id":"WU-001","from_status":"pending","to_status":"in_progress","expected":"ALLOW","reason":"标准状态推进"},
    {"name":"WU in_progress→done 合法(子代理返回)","action":"update_work_unit","wu_id":"WU-001","from_status":"in_progress","to_status":"done","expected":"ALLOW","reason":"子代理完成工作可以标记 done"},
    {"name":"WU done→integrated 合法(RECORD中)","action":"update_work_unit","wu_id":"WU-001","from_status":"done","to_status":"integrated","state":"RECORD","expected":"ALLOW","reason":"主线程在 RECORD 中集成"},
    {"name":"WU done→integrated 在EXECUTE中非法","action":"update_work_unit","wu_id":"WU-001","from_status":"done","to_status":"integrated","state":"EXECUTE","expected":"BLOCK","reason":"集成必须在 RECORD 中进行"},
    {"name":"WU pending→integrated 跳跃非法","action":"update_work_unit","wu_id":"WU-001","from_status":"pending","to_status":"integrated","expected":"BLOCK","reason":"不能跳过中间状态"},
    {"name":"WU done→pending 回退非法","action":"update_work_unit","wu_id":"WU-001","from_status":"done","to_status":"pending","expected":"BLOCK","reason":"done不能回退到pending，应进 failed"},
    {"name":"WU failed→pending 合法(重新拆解)","action":"update_work_unit","wu_id":"WU-001","from_status":"failed","to_status":"pending","expected":"ALLOW","reason":"失败后回 PLAN_STEP 重新拆解"},
    {"name":"WU blocked→in_progress 合法(阻塞解除)","action":"update_work_unit","wu_id":"WU-001","from_status":"blocked","to_status":"in_progress","expected":"ALLOW","reason":"依赖满足后恢复执行"},
    {"name":"COMPLETE检查: 全部integrated→通过","check":"can_complete","work_units":[{"id":"WU-001","status":"integrated"}],"expected":"ALLOW","reason":"所有WU integrated"},
    {"name":"COMPLETE检查: 有done→拒绝","check":"can_complete","work_units":[{"id":"WU-001","status":"integrated"},{"id":"WU-002","status":"done"}],"expected":"BLOCK","reason":"WU-002 未集成"},
    {"name":"COMPLETE检查: 有in_progress→拒绝","check":"can_complete","work_units":[{"id":"WU-001","status":"in_progress"}],"expected":"BLOCK","reason":"有WU仍在执行中"},
    {"name":"COMPLETE检查: 空WU→通过(文档任务)","check":"can_complete","work_units":[],"expected":"ALLOW","reason":"无WU的纯文档/配置任务"},
    {"name":"并行分派: files_allowed互不重叠→允许","check":"can_dispatch_parallel","work_units":[{"id":"WU-001","files_allowed":["src/a.py"],"depends_on":[]},{"id":"WU-002","files_allowed":["src/b.py"],"depends_on":[]}],"expected":"ALLOW","reason":"无依赖且文件边界不重叠"},
    {"name":"并行分派: files_allowed重叠→拒绝","check":"can_dispatch_parallel","work_units":[{"id":"WU-001","files_allowed":["src/a.py"],"depends_on":[]},{"id":"WU-002","files_allowed":["src/a.py"],"depends_on":[]}],"expected":"BLOCK","reason":"并行WU不能写同一文件"},
    {"name":"并行分派: 存在依赖→拒绝","check":"can_dispatch_parallel","work_units":[{"id":"WU-001","files_allowed":["src/a.py"],"depends_on":[]},{"id":"WU-002","files_allowed":["src/b.py"],"depends_on":["WU-001"]}],"expected":"BLOCK","reason":"有依赖链必须串行"},
    {"name":"子代理回收: changed_files在files_allowed内且测试已跑→允许done","action":"accept_subagent_result","work_unit":{"id":"WU-001","files_allowed":["src/a.py"],"acceptance_tests":["pytest tests/test_a.py"],"status":"in_progress","owner":"subagent:worker-a"},"result":{"changed_files":["src/a.py"],"tests_run":["pytest tests/test_a.py"],"status":"done"},"expected":"ALLOW","reason":"子代理结果满足边界和验收要求"},
    {"name":"子代理回收: changed_files越界→拒绝done","action":"accept_subagent_result","work_unit":{"id":"WU-001","files_allowed":["src/a.py"],"acceptance_tests":["pytest tests/test_a.py"],"status":"in_progress","owner":"subagent:worker-a"},"result":{"changed_files":["src/b.py"],"tests_run":["pytest tests/test_a.py"],"status":"done"},"expected":"BLOCK","reason":"主线程必须拒绝越界改动"},
    {"name":"子代理回收: 未运行acceptance_tests→拒绝done","action":"accept_subagent_result","work_unit":{"id":"WU-001","files_allowed":["src/a.py"],"acceptance_tests":["pytest tests/test_a.py"],"status":"in_progress","owner":"subagent:worker-a"},"result":{"changed_files":["src/a.py"],"tests_run":[],"status":"done"},"expected":"BLOCK","reason":"done必须带验收证据"},
    {"name":"子代理回收: 修改.deepship元数据→拒绝done","action":"accept_subagent_result","work_unit":{"id":"WU-001","files_allowed":["src/a.py"],"acceptance_tests":["pytest tests/test_a.py"],"status":"in_progress","owner":"subagent:worker-a"},"result":{"changed_files":[".deepship/state.json"],"tests_run":["pytest tests/test_a.py"],"status":"done"},"expected":"BLOCK","reason":"子代理不得修改持久化元数据"},
    {"name":"集成准入: done且validation passed→允许integrated","action":"integrate_work_unit","work_unit":{"id":"WU-001","status":"done","validation_evidence":"pytest passed"},"validation_status":"passed","expected":"ALLOW","reason":"主线程验证通过后可集成"},
    {"name":"集成准入: done但validation failed→拒绝integrated","action":"integrate_work_unit","work_unit":{"id":"WU-001","status":"done","validation_evidence":"pytest failed"},"validation_status":"failed","expected":"BLOCK","reason":"验证失败必须进入REPAIR或PLAN_STEP"},
    {"name":"集成准入: in_progress不能集成","action":"integrate_work_unit","work_unit":{"id":"WU-001","status":"in_progress"},"validation_status":"passed","expected":"BLOCK","reason":"只能集成done状态的WU"}
  ]
}
