{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deepship-log-entry/1.0",
  "title": "DEEPSHIP Log Entry",
  "type": "object",
  "required": ["from_state", "to_state", "timestamp"],
  "properties": {
    "from_state": {"type": "string", "enum": ["READ_CONTEXT","CLARIFY_INTENT","MAP_REALITY","SELECT_MILESTONE","PLAN_STEP","EXECUTE","VALIDATE","REPAIR","RECORD","ADVANCE","BLOCK","COMPLETE"]},
    "to_state": {"type": "string", "enum": ["READ_CONTEXT","CLARIFY_INTENT","MAP_REALITY","SELECT_MILESTONE","PLAN_STEP","EXECUTE","VALIDATE","REPAIR","RECORD","ADVANCE","BLOCK","COMPLETE"]},
    "reason": {"type": "string"},
    "evidence": {"type": "string"},
    "validation_commands": {"type": "array", "items": {"type": "string"}},
    "result": {"type": "string", "enum": ["ok", "fail", "blocked"]},
    "timestamp": {"type": "string", "format": "date-time"}
  }
}
