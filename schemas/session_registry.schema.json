{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deepship-session-registry/1.0",
  "title": "DEEPSHIP Session Registry",
  "type": "object",
  "required": ["sessions"],
  "properties": {
    "sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "role", "status", "goal", "worktree_path"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "role": {"type": "string", "enum": ["owner", "lane", "observer"]},
          "status": {"type": "string", "enum": ["planning", "executing", "active", "paused", "blocked", "done"]},
          "goal": {"type": "string"},
          "plan_revision": {"type": "string"},
          "worktree_path": {"type": "string"},
          "updated_at": {"type": "string"}
        }
      }
    }
  }
}
