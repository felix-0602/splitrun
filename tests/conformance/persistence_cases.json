{
  "version": "1.0",
  "description": "DEEPSHIP 持久化协议一致性测试。StateStore 必须全部通过。",
  "cases": [
    {"name":"state.json 必填字段完整","check":"validate_schema","file":"state.json","data":{"current_state":"READ_CONTEXT","current_milestone":null,"current_work_unit":null,"last_completed_state":null,"next_action":"init","validation_status":null,"updated_at":"2026-01-01T00:00:00Z"},"expected":"ALLOW","reason":"所有必填字段完整"},
    {"name":"state.json 缺current_state","check":"validate_schema","file":"state.json","data":{"updated_at":"2026-01-01T00:00:00Z"},"expected":"BLOCK","reason":"缺少必填字段"},
    {"name":"state.json 非法状态名","check":"validate_schema","file":"state.json","data":{"current_state":"RANDOM_STATE","updated_at":"2026-01-01T00:00:00Z"},"expected":"BLOCK","reason":"不在状态枚举中"},
    {"name":"work_unit 必填字段完整","check":"validate_schema","file":"work_unit","data":{"id":"WU-001","goal":"test","files_allowed":["a.py"],"status":"pending","owner":"orchestrator"},"expected":"ALLOW","reason":"所有必填字段完整"},
    {"name":"work_unit files_allowed为空","check":"validate_schema","file":"work_unit","data":{"id":"WU-001","goal":"test","files_allowed":[],"status":"pending","owner":"orchestrator"},"expected":"BLOCK","reason":"files_allowed 不能为空"},
    {"name":"log entry 必填字段完整","check":"validate_schema","file":"log_entry","data":{"from_state":"READ_CONTEXT","to_state":"MAP_REALITY","reason":"ok","evidence":"grep","validation_commands":[],"result":"ok","timestamp":"2026-01-01T00:00:00Z"},"expected":"ALLOW","reason":"所有必填字段完整"},
    {"name":"log entry 非法result值","check":"validate_schema","file":"log_entry","data":{"from_state":"READ_CONTEXT","to_state":"MAP_REALITY","reason":"ok","result":"unknown","timestamp":"2026-01-01T00:00:00Z"},"expected":"BLOCK","reason":"result 不在枚举中"},
    {"name":"初始化: .deepship/不存在时自动创建","check":"init","workspace_empty":true,"expected":"ALLOW","reason":"干净项目自动初始化 .deepship/"},
    {"name":"初始化: state.json 初始状态为READ_CONTEXT","check":"init_state","expected_state":"READ_CONTEXT","reason":"新项目从 READ_CONTEXT 开始"},
    {"name":"初始化: work_units.json 初始为空列表","check":"init_work_units","expected_work_units":[],"reason":"新项目无 work units"},
    {"name":"log.jsonl 每行是合法JSON","check":"log_integrity","log_lines":["{\"from_state\":\"READ_CONTEXT\",\"to_state\":\"MAP_REALITY\",\"timestamp\":\"2026-01-01T00:00:00Z\"}","not json"],"expected":"BLOCK","reason":"第2行不是合法JSON"},
    {"name":"log.jsonl 全部合法JSON→通过","check":"log_integrity","log_lines":["{\"from_state\":\"READ_CONTEXT\",\"to_state\":\"MAP_REALITY\",\"timestamp\":\"2026-01-01T00:00:00Z\"}"],"expected":"ALLOW","reason":"所有行合法JSON"}
  ]
}
