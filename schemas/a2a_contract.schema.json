{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deepship-a2a-contract/1.0",
  "title": "DEEPSHIP A2A Contract",
  "type": "object",
  "required": ["type", "lane_goal", "integration_owner_session_id"],
  "properties": {
    "id": {"type": "string"},
    "type": {"type": "string", "enum": ["new_lane_contract"]},
    "lane_goal": {"type": "string", "minLength": 1},
    "integration_owner_session_id": {"type": "string", "minLength": 1},
    "base_plan": {"type": "string"},
    "plan_revision": {"type": "string"},
    "interfaces_to_define_before_execution": {
      "type": "array",
      "items": {"type": "string"}
    },
    "must_not": {
      "type": "array",
      "items": {"type": "string"}
    },
    "created_at": {"type": "string"}
  }
}
